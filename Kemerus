-- ESP
local espBtn = createToggle(playerPage, "👁  ESP (Lihat Semua Player)", 42)

local function removeESP()
    for _, h in pairs(espHighlights) do
        if h and h.Parent then h:Destroy() end
    end
    espHighlights = {}
end

local function addESP()
    removeESP()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= localPlayer then
            local char = plr.Character
            if char then
                local h = Instance.new("Highlight", char)
                h.FillColor = Color3.fromRGB(210,190,140)
                h.OutlineColor = Color3.fromRGB(175,145,90)
                h.FillTransparency = 0.5
                h.OutlineTransparency = 0
                espHighlights[plr.Name] = h
                plr.CharacterAdded:Connect(function(newChar)
                    if espEnabled then
                        task.wait(0.5)
                        if espHighlights[plr.Name] and espHighlights[plr.Name].Parent then
                            espHighlights[plr.Name]:Destroy()
                        end
                        local nh = Instance.new("Highlight", newChar)
                        nh.FillColor = Color3.fromRGB(210,190,140)
                        nh.OutlineColor = Color3.fromRGB(175,145,90)
                        nh.FillTransparency = 0.5
                        nh.OutlineTransparency = 0
                        espHighlights[plr.Name] = nh
                    end
                end)
            end
        end
    end
end

espBtn.MouseButton1Click:Connect(function()
    espEnabled = not espEnabled
    if espEnabled then
        espBtn.Text = "ON"
        espBtn.BackgroundColor3 = Color3.fromRGB(175,145,90)
        espBtn.TextColor3 = Color3.fromRGB(255,248,230)
        addESP()
        Players.PlayerAdded:Connect(function(plr)
            if espEnabled then
                plr.CharacterAdded:Connect(function(char)
                    task.wait(0.5)
                    if not espEnabled then return end
                    local h = Instance.new("Highlight", char)
                    h.FillColor = Color3.fromRGB(210,190,140)
                    h.OutlineColor = Color3.fromRGB(175,145,90)
                    h.FillTransparency = 0.5
                    espHighlights[plr.Name] = h
                end)
            end
        end)
    else
        espBtn.Text = "OFF"
        espBtn.BackgroundColor3 = Color3.fromRGB(195,175,135)
        espBtn.TextColor3 = Color3.fromRGB(80,60,20)
        removeESP()
    end
end)

