-- Minimize Logic
local function setSidebarButtonsVisible(state)
    for _, v in pairs(sidebar:GetChildren()) do
        if v:IsA("TextButton") then
            v.Visible = state
        end
    end
end

mini.MouseButton1Click:Connect(function()
    if minimized then
        main:TweenSize(UDim2.new(0, 420, 0, 300), "Out", "Quad", 0.3, true)
        setSidebarButtonsVisible(true)
        minimized = false
    else
        main:TweenSize(UDim2.new(0, 420, 0, 40), "Out", "Quad", 0.3, true)
        setSidebarButtonsVisible(false)
        minimized = true
    end
end)

-- Dragging Logic
local dragging, dragInput, dragStart, startPos

local function update(input)
    local delta = input.Position - dragStart
    main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = main.Position
    end
end)

header.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UIS.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)

