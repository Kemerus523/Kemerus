    frame.Size = UDim2.new(0, 500, 0, 0)
    tween(frame, {Size = UDim2.new(0, 500, 0, 320)}, 0.35, Enum.EasingStyle.Back)
end)

closeBtn.MouseButton1Click:Connect(function()
    tween(frame, {Size = UDim2.new(0, 500, 0, 0)}, 0.25, Enum.EasingStyle.Quint)
    task.wait(0.27)
    frame.Visible = false
    frameShadow.Visible = false
    openBtn.Visible = true
end)

local minimized = false
mini.MouseButton1Click = nil  -- clear old
miniBtn.MouseButton1Click:Connect(function()
    if minimized then
        tween(frame, {Size = UDim2.new(0, 500, 0, 320)}, 0.3, Enum.EasingStyle.Back)
        minimized = false
    else
        tween(frame, {Size = UDim2.new(0, 500, 0, 42)}, 0.25)
        minimized = true
    end
end)

-- ═══════════════════════════════════════════
-- DRAG (Mouse + Touch)
-- ═══════════════════════════════════════════
local dragging = false
local dragInput, dragStart, startPos

local function updateDrag(input)
    local delta = input.Position - dragStart
    local newPos = UDim2.new(
        startPos.X.Scale, startPos.X.Offset + delta.X,
        startPos.Y.Scale, startPos.Y.Offset + delta.Y
    )
    frame.Position = newPos
    frameShadow.Position = UDim2.new(
        newPos.X.Scale, newPos.X.Offset - 10,
        newPos.Y.Scale, newPos.Y.Offset - 10
    )
end

topBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

topBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement
    or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UIS.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        updateDrag(input)
    end
end)
