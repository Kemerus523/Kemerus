-- ═══════════════════════════════════════════
-- TWEEN HELPER
-- ═══════════════════════════════════════════
local function tween(obj, props, t, style, dir)
    local info = TweenInfo.new(t or 0.3, style or Enum.EasingStyle.Quint, dir or Enum.EasingDirection.Out)
    TweenService:Create(obj, info, props):Play()
end

