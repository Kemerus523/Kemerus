local function createTab(name, icon, order)
    local tab = Instance.new("TextButton", tabBar)
    tab.Size = UDim2.new(1,0,0,38)
    tab.Text = icon .. " " .. name
    tab.BackgroundColor3 = Color3.fromRGB(210,195,168)
    tab.TextColor3 = Color3.fromRGB(80,60,25)
    tab.Font = Enum.Font.GothamBold
    tab.TextSize = 13
    tab.BorderSizePixel = 0
    tab.LayoutOrder = order
    Instance.new("UICorner", tab).CornerRadius = UDim.new(0,7)
    local page = createPage()
    tab.MouseButton1Click:Connect(function()
        for _, v in pairs(pages:GetChildren()) do
            if v:IsA("Frame") then v.Visible = false end
        end
        for _, t in pairs(tabBar:GetChildren()) do
            if t:IsA("TextButton") then
                t.BackgroundColor3 = Color3.fromRGB(210,195,168)
                t.TextColor3 = Color3.fromRGB(80,60,25)
            end
        end
        page.Visible = true
        tab.BackgroundColor3 = Color3.fromRGB(175,145,90)
        tab.TextColor3 = Color3.fromRGB(255,250,240)
    end)
    return tab, page
end

