    or inp.UserInputType == Enum.UserInputType.Touch then
        slidingSpeed = true
    end
end)
UIS.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1
    or inp.UserInputType == Enum.UserInputType.Touch then
        slidingSpeed = false
    end
end)
UIS.InputChanged:Connect(function(inp)
    if slidingSpeed and (
        inp.UserInputType == Enum.UserInputType.MouseMovement
        or inp.UserInputType == Enum.UserInputType.Touch
    ) then
        local bgPos = sliderBg.AbsolutePosition
        local bgSize = sliderBg.AbsoluteSize
        local rel = math.clamp((inp.Position.X - bgPos.X) / bgSize.X, 0, 1)
        customSpeed = math.floor(16 + rel * (200-16))
        sliderLabel.Text = "Speed: " .. customSpeed
        sliderFill.Size = UDim2.new(rel,0,1,0)
        sliderKnob.Position = UDim2.new(rel,-9,0.5,-9)
        if speedEnabled then setSpeed(customSpeed) end
    end
end)

