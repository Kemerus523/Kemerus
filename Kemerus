loginBtn.MouseButton1Click:Connect(function()
    if keyBox.Text == KEY then
        statusLabel.Text = "✓  Key accepted!"
        statusLabel.TextColor3 = Color3.fromRGB(60, 180, 80)

        tween(loginBtn, {BackgroundColor3 = Color3.fromRGB(60, 180, 80)}, 0.2)

        task.wait(0.4)
        local out = TweenService:Create(keyPage, TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Position = UDim2.new(0, 0, 1.2, 0)})
        out:Play()
        out.Completed:Connect(function()
            keyPage.Visible = false
            mainMenu.Visible = true
            mainMenu.Position = UDim2.new(0, 0, -0.1, 0)
            tween(mainMenu, {Position = UDim2.new(0, 0, 0, 0)}, 0.4)
        end)
    else
        statusLabel.Text = "✕  Wrong key! Try again."
        statusLabel.TextColor3 = Color3.fromRGB(210, 70, 60)
        tween(loginBtn, {BackgroundColor3 = Color3.fromRGB(200, 70, 60)}, 0.15)
        task.wait(0.3)
        tween(loginBtn, {BackgroundColor3 = Color3.fromRGB(180, 140, 60)}, 0.3)
        keyBox.Text = ""
    end
end)

