-- // Tab Player
local PlayerTab = Window:CreateTab("👤 Player", 4483362458)
local PlayerSection = PlayerTab:CreateSection("Pengaturan Player")

PlayerTab:CreateButton({
    Name = "Reset Character",
    Callback = function()
        local player = game.Players.LocalPlayer
        if player.Character then
            player.Character:BreakJoints()
        end
        Rayfield:Notify({
            Title = "Reset",
            Content = "Character direset!",
            Duration = 3,
        })
    end,
})

PlayerTab:CreateButton({
    Name = "Bring All Players",
    Callback = function()
        local player = game.Players.LocalPlayer
        local character = player.Character
        if character then
            local rootPart = character:FindFirstChild("HumanoidRootPart")
            if rootPart then
                for _, plr in pairs(game.Players:GetPlayers()) do
                    if plr ~= player and plr.Character then
                        local otherRoot = plr.Character:FindFirstChild("HumanoidRootPart")
                        if otherRoot then
                            otherRoot.CFrame = rootPart.CFrame + Vector3.new(0, 0, 3)
                        end
                    end
                end
                Rayfield:Notify({
                    Title = "Bring Players",
                    Content = "Semua player berhasil dibawa!",
                    Duration = 3,
                })
            end
        end
    end,
})

PlayerTab:CreateInput({
    Name = "Teleport ke Player",
    PlaceholderText = "Masukkan nama player...",
    RemoveTextAfterFocusLost = false,
    Callback = function(Text)
        local player = game.Players.LocalPlayer
        local target = game.Players:FindFirstChild(Text)
        if target and target.Character then
            local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
            local myChar = player.Character
            if myChar and targetRoot then
                local myRoot = myChar:FindFirstChild("HumanoidRootPart")
                if myRoot then
                    myRoot.CFrame = targetRoot.CFrame + Vector3.new(0, 3, 0)
                    Rayfield:Notify({
                        Title = "Teleport",
                        Content = "Berhasil teleport ke " .. Text,
                        Duration = 3,
                    })
                end
            end
        else
            Rayfield:Notify({
                Title = "Error",
                Content = "Player tidak ditemukan!",
                Duration = 3,
            })
        end
    end,
})

