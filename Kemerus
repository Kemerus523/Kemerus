-- ═══════════════════════════════════════════
-- TAB + PAGE FACTORY
-- ═══════════════════════════════════════════
local tabList = {}
local activeTab = nil

local function createPage()
    local page = Instance.new("Frame", pageContainer)
    page.Size = UDim2.new(1, 0, 1, 0)
    page.Visible = false
    page.BackgroundTransparency = 1
    return page
end

local function createTab(icon, labelText, index)
    local tab = Instance.new("TextButton", sidebar)
    tab.Size = UDim2.new(1, -8, 0, 36)
    tab.Position = UDim2.new(0, 4, 0, 6 + (index - 1) * 42)
    tab.BackgroundColor3 = Color3.fromRGB(225, 210, 170)
    tab.BackgroundTransparency = 1
    tab.TextColor3 = Color3.fromRGB(100, 75, 30)
    tab.Font = Enum.Font.GothamBold
    tab.TextSize = 11
    tab.Text = icon .. "  " .. labelText
    tab.AutoButtonColor = false
    Instance.new("UICorner", tab).CornerRadius = UDim.new(0, 8)

    local page = createPage()
    table.insert(tabList, {tab = tab, page = page, index = index})

    tab.MouseButton1Click:Connect(function()
        for _, t in pairs(tabList) do
            t.tab.BackgroundTransparency = 1
            t.tab.TextColor3 = Color3.fromRGB(100, 75, 30)
            t.page.Visible = false
        end
        tab.BackgroundTransparency = 0
        tab.TextColor3 = Color3.fromRGB(80, 50, 10)
        page.Visible = true
        tween(activeLine, {Position = UDim2.new(0, 0, 0, 6 + (index - 1) * 42 + 2)}, 0.25)
    end)

    return page, tab
end

