-- ============================================================
-- // WALKSPEED FIX
-- // Pakai Heartbeat agar tidak di-reset oleh anti-cheat game
-- ============================================================
RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    if State.SpeedEnabled and hum.WalkSpeed ~= State.WalkSpeed then
        hum.WalkSpeed = State.WalkSpeed
    end

    if hum.JumpPower ~= State.JumpPower then
        hum.JumpPower = State.JumpPower
    end
end)

-- Reapply setelah respawn
LocalPlayer.CharacterAdded:Connect(function(char)
    task.wait(0.5)
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        if State.SpeedEnabled then hum.WalkSpeed = State.WalkSpeed end
        hum.JumpPower = State.JumpPower
    end
end)

-- ============================================================
-- // ESP SYSTEM
-- // Drawing API: Box + Nama + Health Bar + Jarak
-- ============================================================
local ESPObjects = {}

local function removeESP(player)
    if ESPObjects[player] then
        for _, d in pairs(ESPObjects[player]) do
            pcall(function() d:Remove() end)
        end
        ESPObjects[player] = nil
    end
end

local function createESP(player)
    if player == LocalPlayer then return end
    removeESP(player)

    -- Box
    local box = Drawing.new("Square")
    box.Visible   = false
    box.Thickness = 1.5
    box.Color     = Color3.fromRGB(255, 60, 60)
    box.Filled    = false

    -- Nama player
    local nameText = Drawing.new("Text")
    nameText.Visible      = false
    nameText.Size         = 13
    nameText.Color        = Color3.fromRGB(255, 255, 255)
    nameText.Center       = true
    nameText.Outline      = true
    nameText.OutlineColor = Color3.fromRGB(0, 0, 0)
    nameText.Font         = Drawing.Fonts.UI

    -- HP bar background
    local hpBg = Drawing.new("Square")
    hpBg.Visible = false
    hpBg.Color   = Color3.fromRGB(20, 20, 20)
    hpBg.Filled  = true

    -- HP bar isi
    local hpFill = Drawing.new("Square")
    hpFill.Visible = false
    hpFill.Filled  = true

    -- Teks jarak
    local distText = Drawing.new("Text")
    distText.Visible      = false
    distText.Size         = 11
    distText.Color        = Color3.fromRGB(200, 200, 200)
    distText.Center       = true
    distText.Outline      = true
    distText.OutlineColor = Color3.fromRGB(0, 0, 0)
    distText.Font         = Drawing.Fonts.UI

    ESPObjects[player] = {
        Box      = box,
        Name     = nameText,
        HpBg     = hpBg,
        HpFill   = hpFill,
        Distance = distText,
    }
end

-- Update ESP loop
RunService.RenderStepped:Connect(function()
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end

        if not ESPObjects[player] then
            createESP(player)
        end

        local drawings = ESPObjects[player]
        if not drawings then continue end

        -- Sembunyikan jika ESP off
        if not State.ESPEnabled then
            for _, d in pairs(drawings) do d.Visible = false end
            continue
        end

        local char     = player.Character
        local rootPart = char and char:FindFirstChild("HumanoidRootPart")
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")

        if not char or not rootPart or not humanoid or humanoid.Health <= 0 then
            for _, d in pairs(drawings) do d.Visible = false end
            continue
        end

        -- Kalkulasi bounding box karakter dari bagian atas ke bawah
        local topPos    = rootPart.Position + Vector3.new(0, 3.2, 0)
        local bottomPos = rootPart.Position - Vector3.new(0, 3.0, 0)

        local topScreen,    topOnScreen,    depth = Camera:WorldToViewportPoint(topPos)
        local bottomScreen, bottomOnScreen         = Camera:WorldToViewportPoint(bottomPos)

        if not topOnScreen or depth <= 0 then
            for _, d in pairs(drawings) do d.Visible = false end
            continue
        end

        local height  = math.abs(bottomScreen.Y - topScreen.Y)
        local width   = height * 0.5
        local centerX = topScreen.X

        -- Jarak
        local myChar = LocalPlayer.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
        local dist = 0
        if myRoot then
            dist = math.floor((rootPart.Position - myRoot.Position).Magnitude)
        end

        -- Render BOX
        drawings.Box.Visible  = true
        drawings.Box.Size     = Vector2.new(width, height)
        drawings.Box.Position = Vector2.new(centerX - width / 2, topScreen.Y)

        -- Render NAMA
        drawings.Name.Visible  = true
        drawings.Name.Text     = player.Name
        drawings.Name.Position = Vector2.new(centerX, topScreen.Y - 16)

        -- Render HP BAR (sisi kiri box)
        local hpRatio = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
        local barW    = 4
        local barX    = centerX - width / 2 - barW - 2
        local barH    = height

        drawings.HpBg.Visible  = true
        drawings.HpBg.Size     = Vector2.new(barW, barH)
        drawings.HpBg.Position = Vector2.new(barX, topScreen.Y)

        drawings.HpFill.Visible  = true
        drawings.HpFill.Size     = Vector2.new(barW, barH * hpRatio)
        drawings.HpFill.Position = Vector2.new(barX, topScreen.Y + barH * (1 - hpRatio))
        -- Merah saat HP rendah, hijau saat HP penuh
        drawings.HpFill.Color = Color3.fromRGB(
            math.floor(255 * (1 - hpRatio)),
            math.floor(255 * hpRatio),
            50
        )

        -- Render JARAK
        drawings.Distance.Visible  = true
        drawings.Distance.Text     = "[" .. dist .. "m]"
        drawings.Distance.Position = Vector2.new(centerX, bottomScreen.Y + 3)
    end
end)

